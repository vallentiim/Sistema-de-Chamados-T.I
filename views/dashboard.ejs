<%- include('partials/header') %>

<nav class="navbar navbar-custom navbar-expand-lg px-3 mb-4">
  <div class="container-fluid">
    <span class="navbar-brand fw-bold">
      <i class="bi bi-ticket-detailed"></i> Meus Chamados
    </span>

    <div class="ms-auto d-flex align-items-center flex-wrap gap-2">
      <span class="text-white">
        <i class="bi bi-person-circle"></i> Olá, <%= usuario.nome %>
      </span>
      <a href="/novo" class="btn btn-light btn-sm fw-bold">
        <i class="bi bi-plus-lg"></i> Novo
      </a>
      <a href="/logout" class="btn btn-outline-danger btn-sm border-0">
        <i class="bi bi-box-arrow-right"></i> Sair
      </a>
    </div>
  </div>
</nav>

<div class="container">
  <div class="card p-4 shadow-sm table-responsive">
    <% if (!chamados || chamados.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-inbox display-6 text-muted"></i>
        <p class="mt-3 mb-2 fw-semibold">Nenhum chamado encontrado</p>
        <p class="text-muted mb-3">Abra seu primeiro chamado para começar.</p>
        <a href="/novo" class="btn btn-primary">
          <i class="bi bi-plus-lg"></i> Abrir chamado
        </a>
      </div>
    <% } else { %>
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Título</th>
            <th>Ilha</th>
            <th>Status</th>
            <th>Prioridade</th>
            <th>Ação</th>
          </tr>
        </thead>
        <tbody>
          <% chamados.forEach((c) => { %>
            <tr>
              <td><strong>#<%= c.id %></strong></td>
              <td><%= c.titulo %></td>
              <td><%= c.ilha || '-' %></td>
              <td>
                <% if (c.status === 'Aberto') { %>
                  <span class="badge badge-aberto">
                    <i class="bi bi-exclamation-circle"></i> Aberto
                  </span>
                <% } else if (c.status === 'Em Andamento') { %>
                  <span class="badge badge-andamento">
                    <i class="bi bi-arrow-repeat"></i> Em Andamento
                  </span>
                <% } else { %>
                  <span class="badge badge-fechado">
                    <i class="bi bi-check-circle"></i> Fechado
                  </span>
                <% } %>
              </td>
              <td>
                <span class="badge bg-secondary"><%= c.prioridade || 'Baixa' %></span>
              </td>
              <td>
                <a href="/chamado/<%= c.id %>" class="btn btn-sm btn-primary">
                  <i class="bi bi-eye"></i> Ver
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>

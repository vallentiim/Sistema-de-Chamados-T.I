<%- include('partials/header') %>

<!-- Tela de detalhes de um chamado -->
<nav class="navbar navbar-custom navbar-expand-lg px-3 mb-4">
  <div class="container-fluid">
    <a href="javascript:history.back()" class="navbar-brand fw-bold text-decoration-none">
      <i class="bi bi-arrow-left"></i> Ticket #<%= chamado.id %>
    </a>
  </div>
</nav>

<div class="container">
  <div class="row g-4">
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex flex-wrap justify-content-between gap-2 align-items-start">
            <h3 class="fw-bold mb-0"><%= chamado.titulo %></h3>

            <!-- Badge visual do status atual -->
            <% if (chamado.status === 'Aberto') { %>
              <span class="badge badge-aberto">Aberto</span>
            <% } else if (chamado.status === 'Em Andamento') { %>
              <span class="badge badge-andamento">Em Andamento</span>
            <% } else { %>
              <span class="badge badge-fechado">Fechado</span>
            <% } %>
          </div>

          <hr>

          <p class="lead mb-4"><%= chamado.descricao || 'Sem descrição informada.' %></p>

          <!-- Exibe link do anexo somente se houver arquivo salvo -->
          <% if (chamado.anexo) { %>
            <div class="p-3 border rounded bg-light-subtle">
              <h6 class="fw-bold mb-2"><i class="bi bi-paperclip"></i> Anexo</h6>
              <a
                href="/uploads/<%= chamado.anexo %>"
                target="_blank"
                class="btn btn-sm btn-info text-white"
                rel="noopener noreferrer"
              >
                <i class="bi bi-file-earmark"></i> Visualizar Arquivo
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm border-primary">
        <div class="card-header bg-primary text-white fw-bold">Detalhes / Status</div>

        <div class="card-body">
          <p class="mb-1 text-muted small">Solicitante</p>
          <p class="fw-bold mb-3"><%= chamado.usuario || '-' %></p>

          <p class="mb-1 text-muted small">Técnico responsável</p>
          <p class="fw-bold mb-3"><%= chamado.tecnico || 'Ninguém assumiu ainda' %></p>

          <p class="mb-1 text-muted small">Prioridade</p>
          <p class="fw-bold mb-3"><%= chamado.prioridade || 'Baixa' %></p>

          <p class="mb-1 text-muted small">SLA</p>
          <p class="fw-bold mb-3">
            <i class="bi bi-clock"></i>
            <%= chamado.sla ? new Date(chamado.sla).toLocaleString('pt-BR') : 'Não definido' %>
          </p>

          <!-- Só técnicos podem alterar o status -->
          <% if (isTecnico) { %>
            <form method="POST" action="/status/<%= chamado.id %>">
              <label class="form-label small text-muted">Alterar status</label>
              <select name="status" class="form-select mb-3">
                <% statusDisponiveis.forEach((status) => { %>
                  <option value="<%= status %>" <%= chamado.status === status ? 'selected' : '' %>><%= status %></option>
                <% }) %>
              </select>

              <button class="btn btn-success w-100" type="submit">
                Atualizar Chamado
              </button>
            </form>
          <% } %>

          <!-- Só mostra o botão de assumir se o chamado ainda não tiver técnico -->
          <% if (isTecnico && !chamado.tecnico) { %>
            <form method="POST" action="/assumir/<%= chamado.id %>" class="mt-2">
              <button class="btn btn-warning w-100 fw-bold" type="submit">
                Assumir chamado
              </button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<nav class="navbar navbar-custom navbar-expand-lg px-3 mb-4">
  <div class="container-fluid">
    <span class="navbar-brand fw-bold">
      <i class="bi bi-shield-lock"></i> Painel Técnico
    </span>

    <div class="ms-auto d-flex align-items-center flex-wrap gap-2">
      <span class="text-white">Olá, <%= usuario.nome %></span>
      <a href="/logout" class="btn btn-outline-danger btn-sm border-0">
        <i class="bi bi-box-arrow-right"></i> Sair
      </a>
    </div>
  </div>
</nav>

<div class="container">
  <div class="row mb-4">
    <% if (contadores && contadores.length > 0) { %>
      <% contadores.forEach((c) => { %>
        <div class="col-6 col-md-3 col-lg-2 mb-2">
          <div class="card text-center border-0 shadow-sm h-100">
            <div class="card-body p-2">
              <small class="text-muted d-block text-uppercase counter-label"><%= c.ilha || 'Sem Ilha' %></small>
              <h4 class="mb-0 fw-bold text-primary"><%= c.total %></h4>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
      <form method="GET" action="/painel-tecnico" class="row g-2 align-items-center">
        <div class="col-auto">
          <select name="ilha" class="form-select form-select-sm">
            <option value="">Todas as Ilhas</option>
            <% for (let i = 1; i <= 10; i++) { %>
              <% const value = `Ilha ${i}`; %>
              <option value="<%= value %>" <%= filtroIlha === value ? 'selected' : '' %>><%= value %></option>
            <% } %>
          </select>
        </div>

        <div class="col-auto">
          <button class="btn btn-dark btn-sm" type="submit">Filtrar</button>
        </div>

        <% if (filtroIlha) { %>
          <div class="col-auto">
            <a href="/painel-tecnico" class="btn btn-outline-secondary btn-sm">Limpar</a>
          </div>
        <% } %>
      </form>
    </div>

    <div class="table-responsive">
      <% if (!chamados || chamados.length === 0) { %>
        <div class="text-center py-5">
          <i class="bi bi-inbox display-6 text-muted"></i>
          <p class="mt-3 mb-0 fw-semibold">Nenhum chamado encontrado para este filtro.</p>
        </div>
      <% } else { %>
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Status</th>
              <th>Título / Usuário</th>
              <th>SLA Limite</th>
              <th class="text-center">Ações</th>
            </tr>
          </thead>

          <tbody>
            <% chamados.forEach((c) => { %>
              <% const slaExpirado = c.sla && new Date(c.sla) < new Date(); %>
              <tr>
                <td><span class="text-muted">#<%= c.id %></span></td>

                <td>
                  <% if (c.status === 'Aberto') { %>
                    <span class="badge badge-aberto">Aberto</span>
                  <% } else if (c.status === 'Em Andamento') { %>
                    <span class="badge badge-andamento">Em Andamento</span>
                  <% } else { %>
                    <span class="badge badge-fechado">Fechado</span>
                  <% } %>
                </td>

                <td>
                  <div class="fw-bold"><%= c.titulo %></div>
                  <small class="text-muted"><%= c.usuario %> - <%= c.ilha || 'Sem Ilha' %></small>
                </td>

                <td>
                  <% if (c.sla) { %>
                    <small class="fw-bold <%= slaExpirado ? 'text-danger' : 'text-success' %>">
                      <i class="bi bi-clock"></i> <%= new Date(c.sla).toLocaleString('pt-BR') %>
                    </small>
                  <% } else { %>
                    <small class="text-muted">Sem SLA</small>
                  <% } %>
                </td>

                <td class="text-center">
                  <div class="d-flex gap-1 justify-content-center">
                    <% if (!c.tecnico) { %>
                      <form method="POST" action="/assumir/<%= c.id %>">
                        <button class="btn btn-sm btn-warning fw-bold" type="submit">Assumir</button>
                      </form>
                    <% } %>

                    <a href="/chamado/<%= c.id %>" class="btn btn-sm btn-outline-primary">Detalhes</a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
